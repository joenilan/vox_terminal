# SSH credentials for uploading releases to apps.zombie.digital
# Copy this file to .env.raspi and fill in your values.
# NEVER commit .env.raspi — it contains your password.

SSH_HOST=192.168.1.151
SSH_USER=dietpi
SSH_PASSWORD=your_password_here
SSH_PORT=22

RPI_RELEASE_BASE_DIR=/mnt/data/sites/apps/public/downloads
RELEASE_APP_SLUG=vox-terminal
RELEASE_CHANNEL=stable
