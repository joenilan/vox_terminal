{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VOX_TERMINAL",
  "mainBinaryName": "vox-terminal",
  "version": "1.0.4",
  "identifier": "com.zmbrt.voxterminal",
  "build": {
    "beforeDevCommand": "bun run vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      },
      "wix": {
        "upgradeCode": "EC3515C7-EFC7-4CE4-B873-06C6D6514CAA"
      }
    }
  }
}
