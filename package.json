{
  "name": "vox-terminal",
  "private": true,
  "version": "1.0.13",
  "author": "ZMBRT",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tsc && tauri build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "version:check": "node ./scripts/version.mjs check",
    "version:check-notes": "node ./scripts/version.mjs check-notes",
    "version:sync": "node ./scripts/version.mjs sync",
    "version:set": "node ./scripts/version.mjs set",
    "version:patch": "node ./scripts/version.mjs patch",
    "version:minor": "node ./scripts/version.mjs minor",
    "version:major": "node ./scripts/version.mjs major",
    "release:windows": "bun run version:check-notes && bun run build && node ./scripts/package-release.mjs",
    "release:publish": "bun run release:windows && node ./scripts/publish-release.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-global-shortcut": "^2",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@types/tmi.js": "^1.8.6",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.25",
    "lucide-react": "^0.556.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.4.0",
    "tmi.js": "^1.8.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.22",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.6",
    "ssh2-sftp-client": "^12.1.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.6"
  }
}
